# PostgreSQL
POSTGRES_USER=stm
POSTGRES_DB=stm
POSTGRES_PASSWORD=mude-essa-senha

# JWT (use uma string longa e aleatória — gere com: openssl rand -hex 32)
JWT_SECRET=mude-para-uma-chave-de-32-chars-ou-mais

# Chave de criptografia do cofre (AES-256, 32+ chars — gere com: openssl rand -hex 32)
# ⚠ NUNCA MUDE depois de ter credenciais salvas, ou elas ficam inacessíveis
VAULT_ENCRYPTION_KEY=mude-para-chave-de-32-chars-ou-mais

# Admin inicial (criado apenas se a base estiver vazia)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@stmarche.com.br
# Deixe ADMIN_PASSWORD vazio para gerar uma senha aleatória (mostrada no log)
ADMIN_PASSWORD=

# Porta HTTP pública
HTTP_PORT=80
